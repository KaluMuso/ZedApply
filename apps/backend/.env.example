# Zed CV Backend — Environment Variables
# Copy this to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Anthropic (for CV parsing, cover letters)
ANTHROPIC_API_KEY=sk-ant-...

# Public URL for redirects (DPO success/cancel, Lenco pending fallback)
APP_PUBLIC_URL=https://zedcv.vercel.app

# DPO Pay — https://docs.dpopay.com/dpo-pay-by-network/reference/dpo-pay-api-v6
DPO_PAY_COMPANY_TOKEN=your-company-token
DPO_PAY_SERVICE_TYPE=your-service-type
DPO_PAY_API_URL=https://secure.3gdirectpay.com/API/v6/
DPO_PAY_CHECKOUT_URL=https://secure.3gdirectpay.com/payv2.php
# Optional overrides (default: APP_PUBLIC_URL/profile?payment=success|cancel)
DPO_PAY_REDIRECT_URL=
DPO_PAY_BACK_URL=
PAYMENT_PROVIDER=dpo_pay

# Lenco (optional provider) — v2 mobile-money collections
LENCO_SECRET_KEY=
LENCO_API_URL=https://api.lenco.co/access/v2
LENCO_CHECKOUT_PATH=collections/mobile-money
LENCO_VERIFY_PATH=collections
LENCO_VERIFY_STATUS_PREFIX=collections/status
LENCO_WEBHOOK_SKIP_VERIFY=false

# WAHA (WhatsApp)
WAHA_API_URL=http://localhost:3001
WAHA_API_KEY=your-waha-api-key

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_EXPIRE_DAYS=30

# App
DEBUG=true
