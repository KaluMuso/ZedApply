{
  "name": "ZedApply - Subscription Renewal Reminder",
  "meta": {
    "description": "Calls POST /admin/trigger-renewal-reminders daily. n8n schedule uses server TZ (UTC on OCI); 08:00 UTC = 10:00 CAT.",
    "scheduleNote": "Cron 0 8 * * * is 08:00 UTC, not 09:00 CAT. For 09:00 CAT use 0 7 * * *."
  },
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * *" }]
        }
      },
      "name": "Daily 08:00 UTC (10:00 CAT)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FASTAPI_URL }}/api/v1/admin/trigger-renewal-reminders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "INGEST_API_KEY", "value": "={{ $env.INGEST_API_KEY }}" },
            { "name": "X-INGEST-API-KEY", "value": "={{ $env.INGEST_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "options": { "timeout": 120000 }
      },
      "name": "Send Renewal Reminder Emails",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Daily 08:00 UTC (10:00 CAT)": {
      "main": [[{ "node": "Send Renewal Reminder Emails", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
