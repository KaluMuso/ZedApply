{
  "name": "ZedApply - Subscription Renewal Reminder",
  "meta": {
    "description": "Same as subscription_renewal_reminder.json (canonical export). Schedule: 0 8 * * * in n8n server TZ (UTC on OCI) = 10:00 CAT.",
    "scheduleNote": "Do not label the trigger 9AM unless cron is 0 7 * * * (07:00 UTC = 09:00 CAT)."
  },
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * *" }]
        }
      },
      "name": "Daily 08:00 UTC (10:00 CAT)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FASTAPI_URL }}/api/v1/admin/trigger-renewal-reminders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "INGEST_API_KEY", "value": "={{ $env.INGEST_API_KEY }}" },
            { "name": "X-INGEST-API-KEY", "value": "={{ $env.INGEST_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}"
      },
      "name": "Send Renewal Reminder Emails",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    }
  ],
  "connections": {
    "Daily 08:00 UTC (10:00 CAT)": {
      "main": [[{ "node": "Send Renewal Reminder Emails", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
